# ─────────────────────────────────────────────
# File2Linken — Environment Variables
# Copy this file to .env for local development
# On Railway: set these in the Variables dashboard
# ─────────────────────────────────────────────

# Server
PORT=8080

# Your public deployment URL (no trailing slash)
# Railway example: https://your-app.up.railway.app
# Local dev: leave blank or set to http://localhost:8080
BASE_URL=https://your-app.up.railway.app

# Telegram Bot Token — from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram API credentials — from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Telegram log channel ID (supergroup: use -100xxxxxxxxxx format)
LOG_CHANNEL_ID=-1001234567890

# Telegram MTProto session string
# On first run, gramjs will authenticate and print the session to logs.
# Copy the printed session string here so restarts reconnect instantly.
TELEGRAM_SESSION=

# PostgreSQL database connection string
# Railway auto-provisions this when you add a Postgres service
DATABASE_URL=postgresql://user:password@host:5432/dbname
